<odoo>
    <!-- Vista kanban personalizada -->
    <record id="view_hr_timesheet_report_by_employee_kanban" model="ir.ui.view">
        <field name="name">hr.timesheet.report.by.employee.kanban</field>
        <field name="model">hr.timesheet.report</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="timesheet_manager_id" widget="many2one_avatar_user"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click">
                            <div>
                                <!-- Nombre del empleado -->
                                <div class="o_kanban_title">
                                    <strong><field name="employee_id"/></strong>
                                </div>
                                <!-- Tipo de contrato -->
                                <div>
                                    <strong>Contract Type:</strong> <field name="contract_type_id"/>
                                </div>
                                <!-- Estructura de salario -->
                                <div>
                                    <strong>Salary Structure Type:</strong> <field name="structure_type_id"/>
                                </div>
                                <!-- Período -->
                                <div>
                                    <strong>Period:</strong> <field name="date_start"/> - <field name="date_end"/>
                                </div>
                                <!-- Estado de la solicitud -->
                                <div>
                                    <field name="request_status" widget="badge" decoration-info="request_status == 'new'" 
                                           decoration-warning="request_status == 'pending'" decoration-success="request_status == 'approved'" 
                                           decoration-danger="request_status == 'refused'"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom" name="studio_auto_kanban_bottom">
                                <div class="oe_kanban_bottom_left" name="studio_auto_kanban_bottom_left"/>
                                <div class="oe_kanban_bottom_right" name="studio_auto_kanban_bottom_right">
                                    <img t-att-src="kanban_image('res.users', 'avatar_128', record.timesheet_manager_id.raw_value)" t-att-title="record.timesheet_manager_id.value || unassigned" t-att-alt="record.timesheet_manager_id.value" class="oe_kanban_avatar o_image_24_cover float-right"/>
                                </div>
                            </div>

                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Vista de tree -->
    <record id="view_hr_timesheet_report_by_employee_tree" model="ir.ui.view">
        <field name="name">hr.timesheet.report.by.employee.tree</field>
        <field name="model">hr.timesheet.report</field>
        <field name="arch" type="xml">
            <tree>
                <field name="employee_id" string="Talent"/>
                <field name="manager_user_id" string="Head of Engineering"/>
                <field name="timesheet_manager_id" string="Project Manager"/>
                <field name="contract_type_id" string="Contract Type"/>
                <field name="structure_type_id"/>
                <field name="department_id" string="Department"/>
                <field name="month"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="request_status" string="Request Status" widget="badge" decoration-info="request_status == 'new'" 
                                           decoration-warning="request_status == 'pending'" decoration-success="request_status == 'approved'" 
                                           decoration-danger="request_status == 'refused'"/>
                <field name="approvers_summary"/>
                <field name="planned_hours" string="Planned Hours"/>
                <field name="effective_hours" string="Effective Hours"/>
                <field name="overtime" string="Overtime"/>
                <field name="management_hours" string="Management Hours"/>
                <field name="time_off_hours" string="Time Off Hours"/>
            </tree>
        </field>
    </record>

